config.jfmuy.title=%MODNAME Config

config.jfmuy.mode=Mode
config.jfmuy.mode.comment=Change the mode that JFMUY is operating in.
config.jfmuy.mode.cheatItemsEnabled=Item Cheating Mode
config.jfmuy.mode.cheatItemsEnabled.comment=Give items instead of showing the recipe.
