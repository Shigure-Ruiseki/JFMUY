config.jfmuy.search=Search Options
config.jfmuy.search.comment=Options relating to the search bar.
config.jfmuy.search.atPrefixRequiredForModName=Require @ for Mod Name
config.jfmuy.search.atPrefixRequiredForModName.comment=Require "@" in front of a word to search by mod name.
config.jfmuy.search.prefixRequiredForTooltipSearch=Require # for Tooltip
config.jfmuy.search.prefixRequiredForTooltipSearch.comment=Require "#" in front of a word to search tooltips.
config.jfmuy.search.prefixRequiredForOreDictSearch=Require $ for Ore Dictionary
config.jfmuy.search.prefixRequiredForOreDictSearch.comment=Require "$" in front of a word to search ore dictionary names.
config.jfmuy.search.prefixRequiredForCreativeTabSearch=Require %% for Creative Tab Name
config.jfmuy.search.prefixRequiredForCreativeTabSearch.comment=Require "%" in front of a word to search creative tab names.
config.jfmuy.search.prefixRequiredForColorSearch=Require ^ for Colors
config.jfmuy.search.prefixRequiredForColorSearch.comment=Require "^" in front of a word to search item colors.

config.jfmuy.advanced=Advanced
config.jfmuy.advanced.comment=Advanced config options to change the way JFMUY functions.
config.jfmuy.advanced.itemBlacklist=Item Blacklist
config.jfmuy.advanced.itemBlacklist.comment=List of items that should not be displayed in the item list. Format: modId[:name[:meta]]. Edit Mode will automatically add or remove entries here.
config.jfmuy.advanced.hideMissingModelsEnabled=Hide Items with Missing Models
config.jfmuy.advanced.hideMissingModelsEnabled.comment=Items with missing models will be hidden from the item list.
config.jfmuy.advanced.hideLaggyModelsEnabled=Hide Items with Laggy Models
config.jfmuy.advanced.hideLaggyModelsEnabled.comment=Items with models that cause a long delay will be hidden from the item list.
config.jfmuy.advanced.colorSearchEnabled=Enable Color Search
config.jfmuy.advanced.colorSearchEnabled.comment=Search items by color and show the searchable item colors on tooltips in the item list.
config.jfmuy.advanced.debugModeEnabled=Debug Mode
config.jfmuy.advanced.debugModeEnabled.comment=Only useful for JFMUY developers, adds thousands of test items and some debug recipes.
config.jfmuy.advanced.deleteItemsInCheatModeEnabled=Delete Items in Cheat Mode
config.jfmuy.advanced.deleteItemsInCheatModeEnabled.comment=In cheat mode, drag an ItemStack over the item list and click to delete it. (requires JFMUY on server)

config.jfmuy.addons=Addons
config.jfmuy.addons.comment=Category for JFMUY addon config options.

